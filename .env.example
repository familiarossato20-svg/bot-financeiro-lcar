# ============================================================
# CONFIGURAÇÕES DO BOT FINANCEIRO - Preencha todos os campos
# ============================================================

# --- GROQ (Transcrição de áudio) ---
# Crie sua chave grátis em: https://console.groq.com
GROQ_API_KEY=sua_chave_groq_aqui

# --- ANTHROPIC (Inteligência do bot) ---
# Crie sua chave em: https://console.anthropic.com
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui

# --- BOTCONVERSA ---
# Encontre em: Configurações > API > Token de acesso
BOTCONVERSA_API_KEY=sua_chave_botconversa_aqui
BOTCONVERSA_ACCOUNT_ID=seu_account_id_aqui

# --- GOOGLE SHEETS ---
# ID da sua planilha (está na URL: docs.google.com/spreadsheets/d/ESTE_ID_AQUI/edit)
GOOGLE_SHEET_ID=id_da_sua_planilha_aqui

# Conteúdo do arquivo JSON da Service Account do Google
# (Cole o conteúdo inteiro do JSON em uma linha só)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# --- SEGURANÇA ---
# Crie uma senha qualquer para proteger seu webhook
WEBHOOK_SECRET=minha_senha_secreta_123

# --- SERVIDOR ---
PORT=3000
